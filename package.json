{
  "name": "steal-context",
  "version": "0.2.0",
  "description": "Type /steal (or /steal kilo|claude|cursor) in any AI coding chat to pull conversation context from another tool. Auto-picks by last human turn across Cursor, Kilo Code, Claude Code, ....",
  "type": "module",
  "bin": {
    "steal-context": "bin/cli.mjs",
    "steal": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "scripts",
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "doctor": "node bin/cli.mjs doctor",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "continues": "^4.1.1"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cursor",
    "kilo-code",
    "claude-code",
    "glm",
    "glm-4-6",
    "glm-5",
    "glm-5-2",
    "claude",
    "claude-opus",
    "opus-4",
    "fireworks",
    "fireworks-ai",
    "context",
    "context-window",
    "handoff",
    "llm",
    "slash-command",
    "continues",
    "mcp",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alonsorobots/steal-context.git"
  }
}
